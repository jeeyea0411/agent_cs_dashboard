    {
      "parameters": {
        "method": "GET",
        "url": "https://pubgsupport.zendesk.com/api/v2/satisfaction_ratings.json",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBasicAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "start_time",
