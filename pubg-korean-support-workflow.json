      "id": "get-csat",
      "name": "Zendesk - CSAT 수집",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [460, 480],
      "credentials": {
        "httpBasicAuth": {
          "id": "zendesk-basic-auth",
          "name": "Zendesk Basic Auth"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// 티켓 데이터\nconst tickets = $('Zendesk - 티켓 수집').first().json.results || [];\n\n// CSAT 데이터\nconst csatList = $('Zendesk - CSAT 수집').first().json.satisfaction_ratings || [];\n\n// CSAT를 ticket_id 기준으로 매핑\nconst csatMap = {};\nfor (const c of csatList) {\n  csatMap[c.ticket_id] = c.score;\n}\n\n// 상담원별 집계\nconst agentMap = {};\nfor (const t of tickets) {\n  const agentId = t.assignee_id;\n  const agentName = t.assignee?.name || `Agent_${agentId}`;\n  if (!agentMap[agentId]) {\n    agentMap[agentId] = { name: agentName, tickets: 0, frtTotal: 0, goodCsat: 0, csatResponses: 0 };\n  }\n  const a = agentMap[agentId];\n  a.tickets++;\n  a.frtTotal += t.reply_time_in_minutes?.calendar || 0;\n  const score = csatMap[t.id];\n  if (score) {\n    a.csatResponses++;\n    if (score.startsWith('good')) a.goodCsat++;\n  }\n}\n\nconst agents = Object.values(agentMap).map(a => ({\n  name: a.name,\n  tickets: a.tickets,\n  avgFRT: a.tickets > 0 ? (a.frtTotal / a.tickets / 60).toFixed(1) + 'h' : '0.0h',\n  csat: a.csatResponses > 0 ? ((a.goodCsat / a.csatResponses) * 100).toFixed(1) + '%' : 'N/A',\n  csatResponses: a.csatResponses,\n})).sort((a, b) => b.tickets - a.tickets);\n\nconst payload = {\n  agents,\n  meta: {\n    brand: 'PUBG',\n    brandId: 114094569274,\n    group: 'Korean Support',\n    vendor: 'Meta-M',\n    generatedAt: new Date().toISOString(),\n    totalAgents: agents.length,\n    totalTickets: agents.reduce((s, a) => s + a.tickets, 0),\n  }\n};\n\nreturn [{ json: payload }];\n"
      },
      "id": "aggregate-code",
      "name": "상담원별 성과 집계",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [700, 380]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// data.json에 넣을 content를 Base64로 인코딩 (GitHub API 요구사항)\nconst payload = $input.first().json;\nconst jsonString = JSON.stringify(payload, null, 2);\nconst base64Content = Buffer.from(jsonString).toString('base64');\n\nreturn [{ json: { content: base64Content, jsonString } }];\n"
      },
      "id": "encode-base64",
      "name": "Base64 인코딩",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [920, 380]
    },
